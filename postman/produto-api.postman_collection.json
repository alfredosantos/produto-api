{
  "info": {
    "_postman_id": "6b5a8c5a-54d8-4f7a-9cd0-16b07453f14e",
    "name": "Produto API - Endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Colecao para validar todos os endpoints da Produto API."
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "produtoId",
      "value": ""
    },
    {
      "key": "nomeBusca",
      "value": "Mouse Gamer"
    }
  ],
  "item": [
    {
      "name": "Docs - Swagger UI",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/docs",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "docs"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Docs - OpenAPI JSON",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/docs/api-docs",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "docs",
            "api-docs"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Retorna objeto OpenAPI', function () {",
              "    var data = pm.response.json();",
              "    pm.expect(data).to.have.property('openapi');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "POST - Criar produto",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nome\": \"Mouse Gamer\",\n  \"descricao\": \"Mouse com RGB\",\n  \"preco\": 129.90,\n  \"quantidade\": 25\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/produtos",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "produtos"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "var data = pm.response.json();",
              "if (data && data.id) {",
              "    pm.collectionVariables.set('produtoId', data.id);",
              "}",
              "if (data && data.nome) {",
              "    pm.collectionVariables.set('nomeBusca', data.nome);",
              "}",
              "pm.test('Produto criado com id', function () {",
              "    pm.expect(data.id).to.be.a('number');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "GET - Listar todos",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/produtos",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "produtos"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Retorna lista', function () {",
              "    pm.expect(pm.response.json()).to.be.an('array');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "GET - Contar produtos",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/produtos/contar",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "produtos",
            "contar"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "GET - Buscar por ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/produtos/{{produtoId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "produtos",
            "{{produtoId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('ID igual ao criado', function () {",
              "    var data = pm.response.json();",
              "    pm.expect(String(data.id)).to.eql(String(pm.collectionVariables.get('produtoId')));",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "GET - Buscar por nome",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/produtos/buscar/{{nomeBusca}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "produtos",
            "buscar",
            "{{nomeBusca}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Retorna lista de produtos', function () {",
              "    pm.expect(pm.response.json()).to.be.an('array');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "PUT - Atualizar produto",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": {{produtoId}},\n  \"nome\": \"Mouse Gamer Pro\",\n  \"descricao\": \"Mouse gamer com RGB e sensor premium\",\n  \"preco\": 159.90,\n  \"quantidade\": 18\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/produtos/{{produtoId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "produtos",
            "{{produtoId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "var data = pm.response.json();",
              "pm.collectionVariables.set('nomeBusca', data.nome);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "DELETE - Remover produto",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/produtos/{{produtoId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "produtos",
            "{{produtoId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 204', function () {",
              "    pm.response.to.have.status(204);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "GET - Buscar por ID apos delete (espera 404)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/produtos/{{produtoId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "produtos",
            "{{produtoId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 404 apos delete', function () {",
              "    pm.response.to.have.status(404);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ]
}

